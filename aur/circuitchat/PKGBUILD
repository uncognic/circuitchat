# Maintainer: uncognic <uncognic@proton.me>
# https://1707070.xyz/openpgp/openpgp.txt

pkgname=circuitchat
pkgver=1.8.6
pkgrel=1
pkgdesc="Encrypted peer-to-peer chat over Tor"
arch=('x86_64')
url="https://github.com/uncognic/circuitchat"
license=('GPL3')
depends=()
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/uncognic/circuitchat/archive/refs/tags/v$pkgver.tar.gz")

pkgver() {
  echo "$pkgver"
}

prepare() {
  _sha256=$(curl -sL "https://github.com/uncognic/circuitchat/releases/download/v$pkgver/sha256.txt")
  echo "$_sha256  $pkgname-$pkgver.tar.gz" | sha256sum --check --quiet || {
    echo "SHA256 mismatch!" >&2
    return 1
  }
}

build() {
  cd "$pkgname-$pkgver"
  cargo build --release
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 target/release/circuitchat "$pkgdir/usr/bin/circuitchat"
}